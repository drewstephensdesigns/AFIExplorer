<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AFIExplorer" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/brand_light</item>
        <item name="colorPrimaryVariant">@color/brand_deep</item>
        <item name="colorOnPrimary">@color/surface_dark</item>

        <item name="colorSecondary">@color/brand_mid</item>
        <item name="colorSecondaryVariant">@color/brand_light</item>
        <item name="colorOnSecondary">@color/surface_dark</item>

        <item name="colorOnTertiaryContainer">@color/brand_accent</item>

        <item name="android:statusBarColor">?colorSurfaceContainerLow</item>
        <item name="android:navigationBarColor">?colorSurfaceContainerLow</item>

        <item name="colorControlNormal">@color/surface_warm</item>
        <item name="colorError">@color/color_error</item>

        <!-- Sheets -->
        <item name="sheetsTitleColor">@color/brand_mid</item>
        <item name="sheetsPrimaryColor">@color/brand_mid</item>
        <item name="sheetsBackgroundColor">?attr/colorSurfaceContainerLow</item>
        <item name="sheetsHighlightColor">@color/brand_accent</item>
        <item name="sheetsDividerColor">@color/brand_mid</item>
        <item name="sheetsContentColor">@color/brand_mid</item>
        <item name="sheetsNegativeButtonColor">@color/brand_accent</item>
        <item name="sheetsContentFont">@font/noto_sans</item>
        <item name="sheetsTitleFont">@font/ibm_plex_sans</item>
    </style>

    <style name="AboutCard" parent="Theme.AFIExplorer">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLow</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="AboutItem">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/noto_sans</item>
        <item name="android:textAlignment">viewStart</item>
        <item name="drawableTint">@color/brand_mid</item>
    </style>

    <style name="PlaceholderCard" parent="Theme.AFIExplorer">
        <item name="cardBackgroundColor">#0003DAC5</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">#0003DAC5</item>
    </style>

</resources>
