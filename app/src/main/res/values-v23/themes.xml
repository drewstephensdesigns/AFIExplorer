<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AFIExplorer" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_deep</item>
        <item name="colorPrimaryVariant">@color/brand_light</item>
        <item name="colorOnPrimary">@color/surface_warm</item>

        <item name="colorSecondary">@color/green_primary</item>
        <item name="colorSecondaryVariant">@color/green_deep</item>
        <item name="colorOnSecondary">@color/surface_dark</item>

        <item name="colorOnTertiaryContainer">#30434A</item>

        <item name="android:statusBarColor">?colorSurfaceContainerLow</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="android:colorControlNormal">@color/surface_dark</item>
        <item name="colorError">@color/color_error</item>

        <!-- Sheets -->
        <item name="sheetsTitleColor">@color/brand_mid</item>
        <item name="sheetsPrimaryColor">@color/brand_mid</item>
        <item name="sheetsHighlightColor">@color/brand_accent</item>
        <item name="sheetsDividerColor">@color/brand_mid</item>
        <item name="sheetsContentColor">@color/brand_mid</item>
        <item name="sheetsIconsColor">@color/surface_warm</item>
        <item name="sheetsNegativeButtonColor">@color/brand_accent</item>
        <item name="sheetsContentFont">@font/noto_sans</item>
        <item name="sheetsTitleFont">@font/ibm_plex_sans</item>
    </style>

    <style name="AboutCard" parent="Theme.AFIExplorer">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="AboutItem">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAlignment">viewStart</item>
    </style>


</resources>
